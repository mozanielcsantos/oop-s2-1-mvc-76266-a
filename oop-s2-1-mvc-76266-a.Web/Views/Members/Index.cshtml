@model IEnumerable<Library.Domain.Entities.Member>

@{
    ViewData["Title"] = "Members";
}

<h1 class="mb-4">Members</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-dark">Add New Member</a>
</div>

@if (!Model.Any())
{
    <p>No members found.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th style="width: 180px;">Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var member in Model)
        {
            <tr>
                <td>@member.FullName</td>
                <td>@member.Email</td>
                <td>@member.Phone</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@member.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@member.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}