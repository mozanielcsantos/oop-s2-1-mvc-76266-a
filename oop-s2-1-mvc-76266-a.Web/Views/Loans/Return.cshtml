@model Library.Domain.Entities.Loan

@{
    ViewData["Title"] = "Return Loan";
}

<h1 class="mb-4">Mark Loan as Returned</h1>

<div class="alert alert-warning">
    Are you sure you want to mark this loan as returned?
</div>

<dl class="row">
    <dt class="col-sm-2">Book</dt>
    <dd class="col-sm-10">@Model.Book?.Title</dd>

    <dt class="col-sm-2">Member</dt>
    <dd class="col-sm-10">@Model.Member?.FullName</dd>

    <dt class="col-sm-2">Due Date</dt>
    <dd class="col-sm-10">@Model.DueDate.ToString("yyyy-MM-dd")</dd>
</dl>

<form asp-action="Return" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-success">Confirm Return</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>