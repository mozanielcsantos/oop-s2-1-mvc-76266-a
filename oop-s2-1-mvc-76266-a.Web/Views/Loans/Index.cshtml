@model IEnumerable<oop_s2_1_mvc_76266_a.Web.Models.LoanListItemVm>

@{
    ViewData["Title"] = "Loans";
}

<h1 class="mb-4">Loans</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-dark">Create Loan</a>
</div>

@if (!Model.Any())
{
    <p>No loans found.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
        <tr>
            <th>Book</th>
            <th>Member</th>
            <th>Loan Date</th>
            <th>Due Date</th>
            <th>Returned Date</th>
            <th>Status</th>
            <th style="width: 160px;">Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var loan in Model)
        {
            var isReturned = loan.ReturnedDate.HasValue;
            var isOverdue = !isReturned && loan.DueDate.Date < DateTime.Today;

            <tr>
                <td>@loan.BookTitle</td>
                <td>@loan.MemberName</td>
                <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                <td>@loan.DueDate.ToString("yyyy-MM-dd")</td>
                <td>@(loan.ReturnedDate.HasValue ? loan.ReturnedDate.Value.ToString("yyyy-MM-dd") : "-")</td>
                <td>
                    @if (isReturned)
                    {
                        <span>Returned</span>
                    }
                    else if (isOverdue)
                    {
                        <span class="text-danger">Overdue</span>
                    }
                    else
                    {
                        <span>Active</span>
                    }
                </td>
                <td>
                    @if (!isReturned)
                    {
                        <a asp-action="Return" asp-route-id="@loan.Id" class="btn btn-sm btn-success">Mark Returned</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}