@model IEnumerable<Library.Domain.Entities.Book>

@{
    ViewData["Title"] = "Books";
}

<h1 class="mb-4">Books</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-dark">Add New Book</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by title or author" />
    </div>

    <div class="col-md-3">
        <select name="category" class="form-select">
            <option value="">All Categories</option>
            @foreach (var category in ViewBag.Categories)
            {
                if ((string?)ViewBag.SelectedCategory == category)
                {
                    <option value="@category" selected>@category</option>
                }
                else
                {
                    <option value="@category">@category</option>
                }
            }
        </select>
    </div>

    <div class="col-md-3">
        <select name="availability" class="form-select">
            @if ((string?)ViewBag.SelectedAvailability == "")
            {
                <option value="" selected>All</option>
            }
            else
            {
                <option value="">All</option>
            }

            @if ((string?)ViewBag.SelectedAvailability == "Available")
            {
                <option value="Available" selected>Available</option>
            }
            else
            {
                <option value="Available">Available</option>
            }

            @if ((string?)ViewBag.SelectedAvailability == "OnLoan")
            {
                <option value="OnLoan" selected>On Loan</option>
            }
            else
            {
                <option value="OnLoan">On Loan</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Search</button>
    </div>
</form>

@if (!Model.Any())
{
    <p>No books found.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>ISBN</th>
                <th>Category</th>
                <th>Status</th>
                <th style="width: 180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.Isbn</td>
                <td>@book.Category</td>
                <td>@(book.IsAvailable ? "Available" : "On Loan")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}