<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Library Management System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body {
            background-color: #f4f1ea;
        }

        .navbar {
            background-color: #2c3e50;
        }

        .navbar a {
            color: white !important;
        }

        .navbar-brand {
            font-weight: bold;
        }
    </style>
</head>

<body>

<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand text-white" asp-controller="Home" asp-action="Index">
            📚 Library Desk
        </a>

        <div>
            <a class="nav-link d-inline" asp-controller="Home" asp-action="Index">Home</a>
            <a class="nav-link d-inline" asp-controller="Books" asp-action="Index">Books</a>
            <a class="nav-link d-inline" asp-controller="Members" asp-action="Index">Members</a>
            <a class="nav-link d-inline" asp-controller="Loans" asp-action="Index">Loans</a>
            <a class="nav-link d-inline" asp-controller="Admin" asp-action="Index">Admin</a>
        </div>

        <partial name="_LoginPartial" />
    </div>
</nav>

<div class="container mt-4">
    @RenderBody()
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>